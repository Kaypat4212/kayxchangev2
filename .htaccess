DirectoryIndex public/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Send the domain root into Laravel's public folder.
    RewriteRule ^$ public/ [L]

    # Avoid rewrite loops for requests already under /public.
    RewriteCond %{REQUEST_URI} !^/public/ [NC]
    RewriteRule ^(assets|Assests|css|js|images|barcodes|storage)/(.*)$ public/$1/$2 [L,NC,QSA]

    # Route common top-level static files through /public.
    RewriteCond %{REQUEST_URI} !^/public/ [NC]
    RewriteRule ^(manifest\.json|robots\.txt|favicon\.ico|favicon\.png|service-worker\.js|serviceworker\.js|sw\.js)$ public/$1 [L,NC,QSA]

    # Catch-all route into /public for Laravel front controller handling.
    RewriteCond %{REQUEST_URI} !^/public/ [NC]
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# Fallback when mod_rewrite is unavailable
<IfModule !mod_rewrite.c>
    RedirectMatch 302 ^/$ /public/
</IfModule>
